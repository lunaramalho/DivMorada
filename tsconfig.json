{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/components/*": ["./src/components/*"],
      "@/styles/*":     ["./src/styles/*"],
      "@/constants/*":  ["./src/constants/*"],
      "@/services/*":   ["./src/services/*"],
      "@/tipos/*":      ["./src/tipos/*"],
      "@/hooks/*":      ["./hooks/*"],
      "@/context/*":    ["./context/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
